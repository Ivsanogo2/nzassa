# Nzassa AI provider order:
# auto = Ollama local -> OpenRouter gratuit -> Hugging Face -> OpenAI -> mode local
NZASSA_AI_PROVIDER=auto

# Option 100% gratuite sans cle si Ollama est installe localement:
# https://ollama.com/download
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen3:4b

# Option recommandee pour commencer gratuitement:
# cree une cle sur https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Option alternative avec credits gratuits limites:
# cree un token sur https://huggingface.co/settings/tokens
HF_TOKEN=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct-1M:fastest

# Option OpenAI payante:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium

# Django local
DJANGO_DEBUG=True
